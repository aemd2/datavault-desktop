# Postgres (Supabase direct URI — Settings → Database)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Notion internal integration secret (same value as connectors.access_token for dev)
NOTION_TOKEN=secret_xxx

# UUID from: insert into public.connectors ... returning id
CONNECTOR_ID=

# Optional: RFC3339 cutoff for: python -m sync_engine sync --incremental
# SYNC_SINCE=2026-01-01T00:00:00.000Z

# Local vault path — where Markdown/CSV/JSON files are written on each sync.
# Defaults to ./vault relative to the working directory if not set.
VAULT_PATH=./vault

# Hours before a connector is considered stale for the check-stale alert command.
STALE_HOURS=26

# --- Email alert settings (optional) ---
# Recipient address for sync failure and stale-sync alerts.
ALERT_EMAIL=you@example.com

# SMTP credentials (for self-hosted or generic SMTP path).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_smtp_password

# Alternative: Resend.com API key (used instead of SMTP when set).
# RESEND_API_KEY=re_xxxxxxxxxx
